---
import MainLayout from "../layouts/MainLayout.astro";
import { Image } from "astro:assets";
// Importamos tu imagen
import errorImg from "../assets/404-error.png";
---

<MainLayout title="404 - Ruta no encontrada">
    <section
        class="min-h-[70vh] flex flex-col items-center justify-center text-center px-4"
    >
        <div class="relative group mb-8">
            <div
                class="absolute -inset-1 bg-brand-scarlet/20 rounded-full blur-3xl group-hover:bg-brand-scarlet/40 transition duration-1000"
            >
            </div>
            <Image
                src={errorImg}
                alt="Error 404"
                class="relative w-full max-w-md md:max-w-lg drop-shadow-[0_0_15px_rgba(220,38,38,0.3)]"
            />
        </div>

        <div class="space-y-4">
            <h1
                class="text-[40vw] font-black text-white opacity-5 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 -z-10 select-none leading-none"
            >
                404
            </h1>

            <h2 class="text-3xl md:text-4xl font-bold text-white">
                ERROR DE <span class="text-brand-red-bright">SEGMENTACIÓN</span>
            </h2>

            <p class="text-text-muted max-w-md mx-auto text-lg">
                Parece que esto apunta a <code
                    class="text-brand-scarlet bg-brand-scarlet/10 px-2 py-1 rounded"
                    >NULL</code
                >. La página que buscas no existe o ha sido movida.
            </p>
        </div>

        <div class="mt-10">
            <a
                href="/"
                class="inline-flex items-center gap-2 bg-brand-scarlet hover:bg-brand-red-bright text-white font-bold py-4 px-8 rounded-xl transition-all hover:scale-105 shadow-lg shadow-brand-scarlet/25"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-5 h-5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"
                    ></path></svg
                >
                Volver al Inicio
            </a>
        </div>
    </section>
</MainLayout>

<style>
    /* Efecto de parpadeo suave para el texto de fondo */
    h1 {
        animation: pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    @keyframes pulse {
        0%,
        100% {
            opacity: 0.05;
        }
        50% {
            opacity: 0.15;
        }
    }
</style>
