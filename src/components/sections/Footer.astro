---
// src/components/Footer.astro
import { Icon } from 'astro-icon/components';
const year = new Date().getFullYear();
const whatsappNumber = "59174322119"; 
---
<footer class="border-t border-border-subtle py-12 mt-20 bg-bg-card/30">
  <div class="max-w-5xl mx-auto px-4">
    <div class="flex flex-col md:flex-row justify-between items-center gap-8">
      
      <div class="text-center md:text-left">
        <p class="text-white font-bold text-lg tracking-tight">Emanuel.dev</p>
        <p class="text-text-muted text-sm mt-1">
          Software Developer <span class="mx-1 text-brand-scarlet">•</span> Cochabamba, Bolivia 🇧🇴
        </p>
      </div>
      
      <div class="flex gap-5">
        <a 
          href={`https://wa.me/${whatsappNumber}`}
          target="_blank" 
          aria-label="WhatsApp"
          class="p-2 rounded-lg bg-bg-page border border-border-subtle text-text-muted hover:text-brand-red-bright hover:border-brand-scarlet transition-all"
        >
          <Icon name="simple-icons:whatsapp" class="w-5 h-5" />
        </a>

        <a 
          href="https://github.com/Dransil" 
          target="_blank" 
          aria-label="GitHub"
          class="p-2 rounded-lg bg-bg-page border border-border-subtle text-text-muted hover:text-brand-red-bright hover:border-brand-scarlet transition-all"
        >
          <Icon name="simple-icons:github" class="w-5 h-5" />
        </a>
        
        <a 
          href="https://linkedin.com/in/emanuel-taquichiri" 
          target="_blank" 
          aria-label="LinkedIn"
          class="p-2 rounded-lg bg-bg-page border border-border-subtle text-text-muted hover:text-brand-red-bright hover:border-brand-scarlet transition-all"
        >
          <Icon name="simple-icons:linkedin" class="w-5 h-5" />
        </a>

        <a 
          href="mailto:taquichiriemanuel0809@gmail.com" 
          aria-label="Email"
          class="p-2 rounded-lg bg-bg-page border border-border-subtle text-text-muted hover:text-brand-red-bright hover:border-brand-scarlet transition-all"
        >
          <Icon name="mdi:email-outline" class="w-5 h-5" />
        </a>
      </div>
    </div>
    
    <div class="text-center text-text-muted text-xs mt-12 opacity-40">
      <p>© {year} — Hecho con Astro y Tailwind</p>
    </div>
  </div>
</footer>