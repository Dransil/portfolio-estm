---
// src/components/sections/ProjectCard.astro
interface Props {
  title: string;
  description: string;
  tags: string[];
  link?: string;
  github?: string;
}

const { title, description, tags, link, github } = Astro.props;
---

<article class="bg-bg-card border border-border-subtle p-6 rounded-2xl hover:border-brand-scarlet hover:shadow-brand-scarlet/10 hover:shadow-2xl transition-all group shadow-xl">
  <div class="flex flex-col h-full">
    <h3 class="text-xl font-bold text-white group-hover:text-brand-red-bright transition">
      {title}
    </h3>
    
    <p class="text-text-muted mt-3 text-sm flex-grow leading-relaxed">
      {description}
    </p>

    <div class="flex flex-wrap gap-2 mt-5">
      {tags.map((tag) => (
        <span class="text-[10px] uppercase tracking-wider font-bold px-2.5 py-1 rounded-md bg-black text-brand-red-bright border border-brand-scarlet/20">
          {tag}
        </span>
      ))}
    </div>

    <div class="flex gap-5 mt-6 pt-4 border-t border-border-subtle">
      {github && (
        <a href={github} target="_blank" class="text-text-muted hover:text-white text-sm flex items-center gap-1 transition">
          <span>GitHub</span> ↗
        </a>
      )}
      {link && (
        <a href={link} target="_blank" class="text-brand-red-bright hover:text-brand-scarlet text-sm font-bold flex items-center gap-1 transition">
          <span>Demo</span> ↗
        </a>
      )}
    </div>
  </div>
</article>